typ main :: Int
def main =
    bench 20000 123456789 0

typ bench :: Int -> Int -> Int -> Int
def bench n x acc =
    if n == 0 then acc
    else {
        def x1 :: Int = lcg x;
        def a :: Int = x1;
        def x2 :: Int = lcg x1;
        def b :: Int = x2;
        def g :: Int = gcd a b;
        bench (n - 1) x2 (acc + g)
    }

typ lcg :: Int -> Int
def lcg x =
    (1103515245 * x + 12345) % 2147483647

typ gcd :: Int -> Int -> Int
def gcd a b =
    if b == 0 then a
    else gcd b (a % b)
